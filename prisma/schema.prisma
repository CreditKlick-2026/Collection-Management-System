generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_jBHmp0hl3JrT@ep-empty-tree-angbicxg-pooler.c-6.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require&connection_limit=10&pool_timeout=10"
}

model User {
  id            Int       @id @default(autoincrement())
  username      String    @unique
  password      String
  name          String
  role          String    // admin, manager, agent
  initials      String
  empId         String    @unique
  managerId     Int?
  manager       User?     @relation("UserManager", fields: [managerId], references: [id])
  subordinates  User[]    @relation("UserManager")
  dob           String?
  doj           String?
  email         String?
  address       String?
  contact       String?
  active        Boolean   @default(true)
  deactReason   String?
  
  assignedLeads Customer[] @relation("AssignedAgent")
  payments      Payment[]  @relation("PaymentAgent")
  ptps          PTP[]      @relation("PTPAgent")
  disputes      Dispute[]  @relation("DisputeAgent")
  settlements   Settlement[] @relation("SettlementAgent")
  
  portfoliosManaged Portfolio[] @relation("PortfolioManagers")
  portfoliosAgent   Portfolio[] @relation("PortfolioAgents")
  auditLogs         AuditLog[]
}

model Customer {
  id            Int       @id @default(autoincrement())
  account_no    String    @unique
  name          String
  mobile        String
  alt_mobile    String?
  alt_mobile_2  String?
  alt_mobile_3  String?
  alt_mobile_4  String?
  email         String?
  pan           String?
  product       String?
  bank          String?
  outstanding   Float     @default(0)
  principle_outstanding Float?
  min_amt_due   Float?
  dpd           Int       @default(0)
  bkt_2         String?
  product_npa   String?
  date_of_npa   String?
  linkage       String?
  upgrade_reason String?
  eligible_upgrade String?
  eligible_for_update String?
  status        String    @default("active")
  city          String?
  state         String?
  dob           String?
  gender        String?
  address       String?
  employer      String?
  salary        Float?
  metadata      Json?     // Flexible JSON for extra spreadsheet columns
  createdAt     DateTime  @default(now())
  
  assignedAgentId Int?
  assignedAgent   User?    @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  
  portfolioId   String?
  portfolio     Portfolio? @relation(fields: [portfolioId], references: [id])
  
  bulkUploadJobId String?  // To track which upload job created/updated this customer
  
  payments      Payment[]
  ptps          PTP[]
  disputes      Dispute[]
  settlements   Settlement[]
}

model LeadColumn {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  order     Int      @default(0)
  visible   Boolean  @default(true)
  showInProfile Boolean @default(true) // Controls visibility in Lead details view
  type      String   @default("text") // text, amount, date, badge
  style     Json?    // Optional custom styles
}

model Payment {
  id              Int       @id @default(autoincrement())
  customerId      Int?
  customer        Customer?  @relation(fields: [customerId], references: [id], onDelete: SetNull)
  
  // Historical tracking fields in case Customer is deleted
  account_no      String?
  customer_name   String?
  
  amount          Float
  mode            String
  ref             String?
  date            String
  agentId         Int
  agent           User      @relation("PaymentAgent", fields: [agentId], references: [id])
  status          String    @default("pending_approval") // pending_approval, cleared, rejected
  remarks         String?
  flag            String?   // flagged, approved, rejected, needs_info, escalated
  flagBy          Int?
  flagComment     String?
  rejectionReason String?
  resolved        Boolean   @default(false)  // Manager lock — if true, agent cannot edit
  resolvedBy      Int?                        // Manager who resolved it
  resolvedAt      DateTime?                   // When it was resolved
  metadata        Json?                       // Upgrade info, swap details, etc.
}

model PTP {
  id              Int       @id @default(autoincrement())
  customerId      Int
  customer        Customer  @relation(fields: [customerId], references: [id])
  amount          Float
  date            String
  status          String    @default("pending")
  agentId         Int
  agent           User      @relation("PTPAgent", fields: [agentId], references: [id])
  voc             String?
  remarks         String?
  flag            String?
  flagComment     String?
  rejectionReason String?
  created         String
}

model Dispute {
  id              Int       @id @default(autoincrement())
  customerId      Int
  customer        Customer  @relation(fields: [customerId], references: [id])
  type            String
  raisedDate      String
  status          String    @default("open")
  agentId         Int
  agent           User      @relation("DisputeAgent", fields: [agentId], references: [id])
  description     String?
  resolution      String?
  flag            String?
  flagComment     String?
  escalated       Boolean   @default(false)
}

model Portfolio {
  id          String   @id
  name        String
  agents      User[]   @relation("PortfolioAgents")
  managers    User[]   @relation("PortfolioManagers")
  customers   Customer[]
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  action      String   // e.g. "PAYMENT_APPROVED", "STATUS_UPDATED", "CALL_LOGGED"
  entityType  String   // e.g. "Payment", "Customer", "PTP"
  entityId    String   // String to support both int IDs and string IDs
  details     Json?    // Stores the delta or extra context
  timestamp   DateTime @default(now())
}
model Settlement {
  id              Int       @id @default(autoincrement())
  customerId      Int
  customer        Customer  @relation(fields: [customerId], references: [id])
  amount          Float     @default(0)
  agentId         Int
  agent           User      @relation("SettlementAgent", fields: [agentId], references: [id])
  managerId       Int?
  reason          String    // Accident, Dispute, Medical, Job loss, Business loss
  subReason       String?   // Death in family, Customer deceased
  justification   String    // Agent Justification
  remarks         String?   // Manager Remarks
  status          String    @default("Raised") // Raised, Pending, Approve, Rejected
  rejectionReason String?
  created         String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model MasterList {
  id    Int    @id @default(autoincrement())
  type  String // PAYMENT_MODE, PTP_STATUS, DISPUTE_STATUS, FLAG_OPTION
  value String
}
model BulkUploadJob {
  id              String    @id @default(cuid())
  status          String    @default("pending") // pending, processing, completed, failed
  totalRows       Int       @default(0)
  processedRows   Int       @default(0)
  successCount    Int       @default(0)
  updatedCount    Int       @default(0)
  skippedCount    Int       @default(0)
  errorCount      Int       @default(0)
  errors          Json?     // Array of error messages
  fileName        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?
}
